# ── Narrator keys (server-side only, never expose to the browser) ──────────
# Put REAL keys in .env.local (gitignored), NOT here.
# Cheapest-first: if DEEPSEEK_API_KEY is set, DeepSeek runs routine turns.
# Get one at https://platform.deepseek.com → API Keys.
DEEPSEEK_API_KEY=sk-...
# Anthropic key powers cinematic turns (Sonnet) and is the fallback narrator.
ANTHROPIC_API_KEY=sk-ant-...

# ── Model routing ───────────────────────────────────────────────────────────
# Routine narrator. Falls back automatically if the matching key is missing.
NARRATOR_MODEL=deepseek-chat
# "Cinematic mode" model (richer prose, higher cost).
CINEMATIC_MODEL=claude-sonnet-5
# Scene summaries / feature-request formatting.
SUMMARIZER_MODEL=deepseek-chat
# DeepSeek sampling temperature for routine narration (default 0.8). Lower =
# tighter, more on-format turns; higher (toward 1.0+) = more varied prose.
NARRATOR_TEMPERATURE=0.8

# ── Supabase (optional — app runs in-memory without these) ──────────────────
# New-style keys (publishable/secret). Legacy anon/service_role also work if
# you swap the names back, but these are the current Supabase defaults.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
